{
  "test": "window_matching_C2",
  "description": "Galaxy-adapted window matching: resample 67 SPARC galaxies onto ~10 log-spaced radii in [0.5, 5] \u00d7 R_half, run Lomb-Scargle periodicity detection. Tests whether SPARC periodicity survives simulation-like sampling.",
  "parameters": {
    "n_window_pts": 10,
    "r_half_range": [
      0.5,
      5.0
    ],
    "spacing": "log",
    "n_surrogates": 200,
    "perm_alpha": 0.05,
    "min_resamp_pts": 5,
    "min_sparc_pts": 15
  },
  "sample": {
    "n_sparc_galaxies": 67,
    "n_valid_window": 67,
    "n_skipped_reff": 0,
    "n_skipped_coverage": 0,
    "median_usable_pts": 9.0,
    "usable_pts_range": [
      5,
      10
    ]
  },
  "periodic_fractions": {
    "full_sparc": {
      "n_periodic": 25,
      "n_total": 67,
      "fraction": 0.3731,
      "label": "Full SPARC (all points, \u226515 per galaxy)"
    },
    "window_matched": {
      "n_periodic": 7,
      "n_total": 67,
      "fraction": 0.1045,
      "label": "10 log-spaced pts in [0.5, 5] \u00d7 R_half"
    },
    "eagle_reference": {
      "n_periodic": 251,
      "n_total": 8837,
      "fraction": 0.0284,
      "label": "EAGLE 10 fixed radii (1-100 kpc)"
    }
  },
  "recovery_analysis": {
    "n_orig_periodic_in_valid": 25,
    "n_recovered": 2,
    "recovery_rate": 0.08,
    "n_orig_nonperiodic_in_valid": 42,
    "n_false_positives": 5,
    "false_positive_rate": 0.119
  },
  "statistical_tests": {
    "binomial_vs_eagle": {
      "test": "binom(n_window_periodic, n_valid, 0.028, greater)",
      "p_value": 0.002700603494978627,
      "interpretation": "Is window fraction significantly above EAGLE 2.8%?"
    },
    "binomial_vs_full_sparc": {
      "test": "binom(n_window_periodic, n_valid, 0.373, less)",
      "p_value": 7.360176878015197e-07,
      "interpretation": "Is window fraction significantly below full SPARC 37.3%?"
    },
    "mcnemar_paired": {
      "both_detected": 2,
      "full_only": 23,
      "window_only": 5,
      "neither": 37,
      "p_value": 0.0009122341871261597
    }
  },
  "wavelength": {
    "window_detected": {
      "n": 7,
      "median_kpc": 11.71,
      "q25_kpc": 2.9,
      "q75_kpc": 15.57
    },
    "full_detected": {
      "n": 25,
      "median_kpc": 6.46,
      "q25_kpc": 2.9,
      "q75_kpc": 16.49
    }
  },
  "verdict": "PERIODICITY_REDUCED_BUT_SIGNIFICANT \u2014 Window matching reduces periodicity but it remains well above EAGLE's 2.8%. The SPARC signal is partially robust to coarse sampling.",
  "eagle_interpretation": "SPARC still shows >3\u00d7 EAGLE's periodic fraction even under matched sampling, supporting a genuine physical difference.",
